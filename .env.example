# HTTP port (default: 4317)
PORT=4317

# Path to the claude binary (default: claude)
CLAUDE_BIN=claude

# Default Claude model (default: claude-sonnet-4-6)
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6

# Timeout for a single Claude request in ms (default: 300000 = 5 min)
CLAUDE_TIMEOUT_MS=300000

# Working directory for Claude (optional, defaults to process cwd)
# CLAUDE_CWD=/path/to/project

# Bearer token for API authentication (optional, disables auth if unset)
# API_TOKEN=your-secret-token

# Allowed CORS origins, comma-separated (default: *)
CORS_ORIGINS=*
